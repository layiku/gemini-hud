# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
jspm_packages/

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
build/

# ── gemini-hud exports ────────────────────────────────────────────────────────
# Files generated by `gemini-hud --export json|csv`
gemini-hud-export-*.json
gemini-hud-export-*.csv

# ── Local configuration ───────────────────────────────────────────────────────
# User-specific settings; copy from .gemini-hudrc.example to customize
.gemini-hudrc

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
